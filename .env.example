# ----------------------------------------------------------------------------
# Hodos landing page — environment variables.
# Copy to .env.local and fill in. Never commit .env.local.
# ----------------------------------------------------------------------------

# Supabase (waitlist + feedback + accounts/cloud-sync backend)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=          # server-only — must NEVER reach the client bundle
# Public anon (publishable) key — safe in the client. Set this to TURN ON real
# accounts + cloud sync (Supabase Auth). Leave blank to stay local-first.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Salt for hashing client IPs (sha256(ip + secret + day)). Any long random string.
WAITLIST_RATE_LIMIT_SECRET=

# Canonical site URL (used for metadata, OG, robots, sitemap)
NEXT_PUBLIC_SITE_URL=https://hodos.app

# Plausible analytics — set to your verified domain to enable the script.
# Leave blank to disable analytics entirely (e.g. in local dev).
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Feature flag — the /app canvas. "true" enables it; anything else 404s.
# Set to true on Vercel PREVIEW environments only until the v1 cutover.
NEXT_PUBLIC_HODOS_APP_ENABLED=

# Resend — beta invite emails (emails/beta-invite.tsx). Not needed to run the app.
RESEND_API_KEY=
