  "nodes": [
    {
      "id": "q-mel",
      "mapId": "root",
      "type": "question",
      "content": "Who is Melchizedek, and why does the Bible keep circling back to him?",
      "position": {
        "x": 0,
        "y": 0
      },
      "createdAt": 1749513600000,
      "updatedAt": 1749513600000
    },
    {
      "id": "v-gen1418",
      "mapId": "root",
      "type": "verse",
      "content": "",
      "position": {
        "x": -360,
        "y": 230
      },
      "createdAt": 1749513601000,
      "updatedAt": 1749513601000,
      "verseRef": "Genesis 14:18",
      "verseText": "Then Melchizedek king of Salem brought out bread and wine—since he was priest of God Most High—"
    },
    {
      "id": "v-heb71",
      "mapId": "root",
      "type": "verse",
      "content": "",
      "position": {
        "x": 360,
        "y": 230
      },
      "createdAt": 1749513602000,
      "updatedAt": 1749513602000,
      "verseRef": "Hebrews 7:1",
      "verseText": "This Melchizedek was king of Salem and priest of God Most High. He met Abraham returning from the slaughter of the kings and blessed him,"
    },
    {
      "id": "v-heb73",
      "mapId": "root",
      "type": "verse",
      "content": "",
      "position": {
        "x": 0,
        "y": 320
      },
      "createdAt": 1749513603000,
      "updatedAt": 1749513603000,
      "verseRef": "Hebrews 7:3",
      "verseText": "Without father or mother or genealogy, without beginning of days or end of life, like the Son of God, he remains a priest for all time."
    },
    {
      "id": "q-superior",
      "mapId": "root",
      "type": "question",
      "content": "What makes his priesthood superior to the Levitical one?",
      "position": {
        "x": 700,
        "y": -40
      },
      "createdAt": 1749513604000,
      "updatedAt": 1749513604000
    },
    {
      "id": "v-ps1104",
