      "updatedAt": 1749513605000,
      "verseRef": "Psalm 110:4",
      "verseText": "The LORD has sworn and will not change His mind: “You are a priest forever in the order of Melchizedek.”"
    },
    {
      "id": "q-forever",
      "mapId": "root",
